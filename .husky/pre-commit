# Block .env.local from being committed
if git diff --cached --name-only | grep -q '\.env\.local$'; then
  echo "ERROR: .env.local is staged for commit. Unstage it with: git reset HEAD .env.local"
  exit 1
fi

# R6 (schema-drift-recurrence proposal, 2026-04-20): warn when prisma/schema.prisma
# is staged but no file under prisma/migrations/ is. This is the author-time
# mirror of the `schema-migration-match` CI job. Warns (does not block) — there
# are legitimate cases (comment-only edits, rename a field with no column
# change). But the warning is loud enough that the typical "I forgot the
# migration" class gets caught before it lands on main.
STAGED=$(git diff --cached --name-only)
SCHEMA_STAGED=$(echo "$STAGED" | grep -E '^app/prisma/schema\.prisma$|^prisma/schema\.prisma$' || true)
MIGRATION_STAGED=$(echo "$STAGED" | grep -E '^app/prisma/migrations/|^prisma/migrations/' || true)

if [ -n "$SCHEMA_STAGED" ] && [ -z "$MIGRATION_STAGED" ]; then
  echo ""
  echo "⚠  WARNING — schema.prisma is staged but no prisma/migrations/ file is."
  echo ""
  echo "    Every schema change needs a matching prisma/migrations/<date>_<desc>/migration.sql"
  echo "    committed alongside AND applied to prod via Supabase SQL Editor (PLAYBOOK Rule 12)."
  echo ""
  echo "    If this is a comment-only or cosmetic edit, proceed. Otherwise: add the migration file,"
  echo "    run the SQL against prod, then re-commit. See the external-config checklist in PLAYBOOK."
  echo ""
  echo "    (The schema-validate GH Action will fail on push if a real drift reaches main.)"
  echo ""
fi

# 2026-05-12 event-data-model proposal (PR-3): the `topic` + `topicSource`
# columns on NegotiationLink are being retired in favor of `customTitle`.
# New code must read from `customTitle ?? topic` during the migration window
# (PR-3) and from `customTitle` exclusively after the deferred drop (PR-4).
# This lint blocks NEW `link.topic` / `session.link.topic` reader sites from
# being added — existing sites under PR-3 use the `customTitle ?? topic` shim
# and are allowed (recognized by the comment marker on the same line).
NEW_TOPIC_READS=$(git diff --cached --unified=0 -- 'app/src/**/*.ts' 'app/src/**/*.tsx' 2>/dev/null \
  | grep -E '^\+' \
  | grep -v '^\+\+\+' \
  | grep -E '\b(link|sess|session)[?]?\.topic\b' \
  | grep -vE 'customTitle.*\.topic|topic: true|PR-3 reader-switchover' \
  || true)

if [ -n "$NEW_TOPIC_READS" ]; then
  echo ""
  echo "✗  BLOCKED — new \`link.topic\` reader added without the customTitle shim."
  echo ""
  echo "    The \`topic\` column is being retired (2026-05-12 event-data-model proposal,"
  echo "    PR-3 in flight, PR-4 drop deferred ≥3 weeks). New readers must use:"
  echo ""
  echo "        link.customTitle ?? link.topic"
  echo ""
  echo "    Add a \`// PR-3 reader-switchover: prefer customTitle\` comment on the line"
  echo "    above to mark the site as migration-aware."
  echo ""
  echo "    Offending lines:"
  echo "$NEW_TOPIC_READS" | sed 's/^/      /' | head -10
  echo ""
  exit 1
fi
