{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && PATH=\"/opt/homebrew/bin:$PATH\" npm run check",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Push complete. Run `vercel ls` or `scripts/check-deploy.sh` to check deploy status.'"
          }
        ]
      }
    ]
  }
}
