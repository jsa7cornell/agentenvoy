{
  "name": "calendar-basic-morning-phone",
  "description": "Host wants a morning phone call with Sarah about Q2 Roadmap, 3 slots available",
  "domain": "calendar",
  "context": {
    "role": "coordinator",
    "hostName": "John",
    "guestName": "Sarah",
    "guestEmail": "sarah@acme.com",
    "topic": "Q2 Roadmap",
    "rules": { "format": "phone", "preferredTimes": ["morning"] },
    "availableSlots": [
      { "start": "2026-04-08T09:00:00", "end": "2026-04-08T09:30:00" },
      { "start": "2026-04-08T10:00:00", "end": "2026-04-08T10:30:00" },
      { "start": "2026-04-09T09:00:00", "end": "2026-04-09T09:30:00" }
    ]
  },
  "trigger": "greeting",
  "assertions": [
    { "type": "contains", "value": "Sarah" },
    { "type": "contains", "value": "Q2 Roadmap" },
    { "type": "contains", "value": "phone" },
    { "type": "not_contains", "value": "video" },
    { "type": "not_contains", "value": "What format" },
    { "type": "not_contains", "value": "prefer" },
    { "type": "contains_any", "values": ["9:00", "9:30", "10:00", "10:30", "9 AM", "10 AM", "9am", "10am"] },
    { "type": "max_length", "value": 600 }
  ]
