{
  "name": "calendar-phone-only-constraint",
  "description": "Format explicitly set to phone — agent should NOT ask about format preferences",
  "domain": "calendar",
  "context": {
    "role": "coordinator",
    "hostName": "John",
    "guestName": "Alex",
    "topic": "Project sync",
    "rules": { "format": "phone" },
    "availableSlots": [
      { "start": "2026-04-08T14:00:00", "end": "2026-04-08T14:30:00" },
      { "start": "2026-04-09T11:00:00", "end": "2026-04-09T11:30:00" }
    ]
  },
  "trigger": "greeting",
  "assertions": [
    { "type": "contains", "value": "Alex" },
    { "type": "contains_any", "values": ["phone", "call"] },
    { "type": "not_contains", "value": "video" },
    { "type": "not_contains", "value": "What format" },
    { "type": "not_contains", "value": "prefer a phone" },
    { "type": "not_contains", "value": "Would you prefer" },
    { "type": "max_length", "value": 600 }
  ]
}
