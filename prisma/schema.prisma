generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// AgentEnvoy models
model User {
  id                          String    @id @default(cuid())
  name                        String?
  email                       String?   @unique
  emailVerified               DateTime?
  image                       String?
  meetSlug                    String?   @unique
  preferences                 Json?     @default("{}")
  hostDirectives              Json?     @default("[]") // string[] — global ::: directives that shape all negotiations
  persistentKnowledge         String?   @db.Text // Long-lived: who they are, how they work, what matters
  upcomingSchedulePreferences String?   @map("situationalKnowledge") @db.Text // Near-term non-time context: mood, goals, temp rules
  lastCalibratedAt            DateTime? // null = never calibrated, triggers onboarding flow
  onboardingPhase             String? // null = not started, tracks progress through onboarding chat
  /// Admin gate. "user" | "admin". Replaces the ADMIN_EMAIL env-var check in
  /// src/lib/admin-auth.ts. Default "user" so migration is additive; John's
  /// row is seeded to "admin" in the same migration. Env-var fallback stays
  /// for 24–48h, removed in the next PR.
  userClass                   String    @default("user")
  /// F4 — beta-cohort debug consent. When true, admins may read this user's
  /// thread + calendar via admin drawers without per-incident consent. Checked
  /// fresh per-request (not cached). Revocation is immediate — flip to false
  /// and `debugConsentRevokedAt` gets stamped; audit rows are kept by F5.
  debugConsent                Boolean   @default(false)
  debugConsentAt              DateTime?
  debugConsentRevokedAt       DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  negotiationLinks  NegotiationLink[]
  hostedSessions    NegotiationSession[] @relation("host")
  guestSessions     NegotiationSession[] @relation("guest")
  participations    SessionParticipant[]
  apiKeys           ApiKey[]
  channel           Channel?
  calendarCaches    CalendarCache[]
  computedSchedule  ComputedSchedule?
  adminAccessLogs   AdminAccessLog[]     @relation("AdminAccessLogs")
  feedbackReports   FeedbackReport[]
  agentTokensMinted AgentAccessToken[]   @relation("AgentTokensMinted")
  productEvents     ProductEvent[]
  onboardingEvents  OnboardingEvent[]
  notifications     Notification[]
}

/// Lean onboarding instrumentation. See proposal
/// `2026-04-21_lean-first-run-onboarding-and-returnto_*.md` §2.5.
/// Two event kinds for v1: `entered` and `completed`. PII-free: no freetext,
/// no metadata blob, so the stream is safe to query without redaction.
/// Dedup of `entered` is enforced in application code (24h window) rather
/// than via a DB constraint so we can extend with goal-level events later.
model OnboardingEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String   // "entered" | "completed"
  entryPoint  String?  // "front-door" | "deal-room" | "deal-room-upsell" (null on completed)
  hasReturnTo Boolean  @default(false)
  at          DateTime @default(now())

  @@index([userId, at])
  @@index([kind, at])
}

/// User-submitted feedback bundle (F3 of the feedback-loops proposal).
/// Per-incident consent model: `checklistState` records what the user
/// agreed to attach, `bundle` is the server-generated redacted payload.
/// Calendar events in `bundle` are redacted at the sink
/// (src/lib/feedback/redact-calendar.ts).
///
/// Host-keyed: `userId` is the LINK OWNER, not the filer. For guest-filed
/// reports (filedByGuest=true), the filer's identity is guestName/guestEmail.
/// Deal-room guest submissions key to the host because (a) host owns the
/// room, (b) host's account-delete cascade is the correct retention story,
/// (c) nothing else is stable to key on for a guest. See
/// proposals/2026-04-21_deal-room-send-feedback-symmetry_reviewed-2026-04-21_decided-2026-04-21.md.
model FeedbackReport {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId      String?
  /// Free-text user message. Optional because Haiku prefill may submit
  /// verbatim without the user typing anything (deal-room symmetry proposal,
  /// 2026-04-21). Before that proposal this field was required.
  userText       String?   @db.Text
  triedToDoText  String?   @db.Text
  userAgent      String?
  url            String?
  checklistState Json
  bundle         Json
  /// True when submitted via the linkCode-authenticated guest endpoint
  /// (`/api/feedback/submit-as-guest`). Server-authoritative — set at the
  /// endpoint boundary, never read from the request body.
  filedByGuest   Boolean   @default(false)
  /// Guest identity at time of report — SNAPSHOT, intentionally not a join.
  /// Server-derived from NegotiationSession state (what the guest volunteered
  /// in join/greeting flow). Never accepted from request body. Null when
  /// filedByGuest=false or when the guest never provided it.
  guestName      String?
  /// See guestName. Snapshot, server-derived.
  guestEmail     String?
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  /// Triage status — "new" | "acknowledged" | "in_progress" | "resolved" | "wontfix".
  /// Filer-visible via /feedback/mine; admin-editable from /admin/feedback/:id.
  /// `resolved` + `wontfix` also stamp resolvedAt/resolvedBy for back-compat
  /// with the existing `resolved: Boolean` column (kept for index stability).
  status         String    @default("new")
  /// Optional area tag — axes intentionally fuzzy for v1 rough-grain triage.
  /// Enum at the validation layer, stored as nullable text. See
  /// proposals/2026-04-21_agent-accessible-feedback-pipeline §4a.
  area           String?
  /// T3b client-state dump — window.location.hash, focused element / session,
  /// viewer timezone, viewport, last-seen message id. User-device context,
  /// no third-party data. See src/lib/feedback/capture-client-state.ts.
  clientState    Json?
  createdAt      DateTime  @default(now())

  agentTokens AgentAccessToken[]

  @@index([userId])
  @@index([createdAt])
  @@index([resolved, createdAt])
  @@index([filedByGuest, createdAt])
  @@index([status, createdAt])
  @@index([area, createdAt])
}

/// Per-report short-lived signed token minted by an admin from
/// /admin/feedback/:id so an agent (Claude Code, etc.) can fetch one
/// FeedbackReport without carrying a NextAuth session cookie. Scoped to
/// a single report, revocable, 15-min TTL, capped at 10 fetches. See
/// proposals/2026-04-21_agent-accessible-feedback-pipeline §2 + §6.
model AgentAccessToken {
  id         String         @id @default(cuid())
  reportId   String
  report     FeedbackReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  /// The admin who minted the token. Reads done via this token are attributed
  /// to THIS user in AdminAccessLog — the agent acts on their behalf.
  mintedById String
  mintedBy   User           @relation("AgentTokensMinted", fields: [mintedById], references: [id], onDelete: Cascade)
  /// JWT id claim — matches the signed JWT's jti. We store jti + expiresAt
  /// but never the JWT body itself.
  jti        String         @unique
  expiresAt  DateTime
  usedAt     DateTime?
  /// Incremented per successful fetch; caps at 10 per TTL per §6.5 rate limit.
  fetchCount Int            @default(0)
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([reportId])
  @@index([mintedById])
  @@index([expiresAt])
}

/// Break-glass audit of every admin read of user-specific data (F5 of the
/// feedback-loops proposal). Written via logAdminAccess() in src/lib/admin/
/// access-log.ts. `path` stores the route template (literal ":id"), not the
/// resolved path — targetUserId carries the resolved user. `/admin/access-log`
/// itself is exempt from logging to avoid a self-filling loop.
model AdminAccessLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminAccessLogs", fields: [adminId], references: [id], onDelete: Cascade)
  targetUserId String?
  path         String
  action       String // "view" | "list" | "export" — enforced at the logger boundary via Zod
  contextJson  Json?
  createdAt    DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
}

/// Always-on product analytics event stream (F2 of the feedback-loops
/// proposal, 2026-04-20 — revised 2026-04-21 to replace PostHog with a
/// self-hosted Supabase table). Written via src/lib/analytics/track.ts,
/// which enforces a name allowlist and a scalar-only prop shape so
/// free-text content cannot leak into the stream by construction.
///
/// `userId` is raw (not hashed) — the internal stack already sees it,
/// the stream stays on Supabase, and hashing would just add indirection.
/// Anonymous pre-auth events carry null.
model ProductEvent {
  id        String   @id @default(cuid())
  name      String // e.g. "onboarding.phase_entered" — enforced against allowlist at write time
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String? // web-session correlator (nullable for anonymous + server events)
  props     Json? // scalar-only bag: { phase: "defaults_format" }, { reason: "scope_denied" }
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique // SHA-256 hash of the plaintext key
  userId     String
  name       String    @default("Default")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
}

model NegotiationLink {
  id              String    @id @default(cuid())
  userId          String
  type            String    @default("primary") // primary | contextual | office_hours
  mode            String    @default("single") // "single" | "group"
  slug            String // same as user.meetSlug for primary
  code            String?   @unique // unique code for contextual links
  inviteeEmail    String?
  inviteeName     String? // deprecated — use inviteeNames; kept for 2-week read bridge
  inviteeNames    String[] @default([])
  /// Host-declared guest timezone (IANA). Seed for session.guestTimezone at
  /// session creation. Null = unknown, fall back to browser-observed TZ. Acts
  /// as a soft-lock: once the session persists a TZ, observed browser TZ does
  /// not override it until the greeting re-render path ships.
  inviteeTimezone String?
  /// Free-text host framing surfaced verbatim in the guest greeting as
  /// `💬 {hostFirstName}: {hostNote}`. Sanitized via sanitizeHostFlavor at
  /// create_link time (injection markers + URLs/emails/phones stripped).
  /// Display-only — do NOT include in computeInputHash; has no effect on
  /// scoring/availability.
  hostNote        String?   @db.VarChar(280)
  topic           String?
  /// Typed via Zod schema in `src/lib/link-parameters.ts` — the JSON shape
  /// covers duration, format, VIP, gating, dayWindowOverrides, blockedDates,
  /// activity, location, topic, etc. Use `parseLinkParameters(parameters)`
  /// at every read site rather than ad-hoc casts. (Renamed from `rules` in
  /// Phase 6 — CODEBASE-CLEANUP item 12 — to remove the false implication
  /// that this is a recurring-window rule.)
  parameters      Json?     @default("{}")
  /// The recurring window this link is bound to (formerly sourceRuleId, used
  /// only for office hours). Now generalized to any reusable variant: the
  /// session's offerable slots are filtered through the window. Null for
  /// normal primary/contextual links. The window lives in the user's
  /// preferences.explicit.structuredRules JSON, not a relation.
  recurringWindowId String?
  expiresAt       DateTime?
  /// Per-link salt for hashing guest emails in MCPCallLog. Postgres ≥13
  /// built-in `gen_random_uuid()` (no pgcrypto). Prevents cross-link
  /// correlation: same email on two different links hashes to different
  /// values. See src/lib/mcp/email-hash.ts and SPEC §4.
  /// Form matches Postgres's canonical storage: `(gen_random_uuid())::text`.
  /// Without the outer parens, Postgres rewrites the default internally and
  /// `prisma migrate diff` reports phantom drift.
  hashSalt        String    @default(dbgenerated("(gen_random_uuid())::text"))
  /// LinkRecurrence shape (null = one-off). See src/lib/recurrence.ts for the
  /// TypeScript type. Non-recurring links leave this null. Writing this field
  /// is the source of truth that a link is a committed series.
  recurrence      Json?
  /// Google Calendar event id of the recurring master event written at anchor
  /// commit. Null until the series is committed. Per-instance overrides use
  /// this id as `recurringEventId` on their instance rows (see
  /// LinkOccurrence.gcalInstanceId). Cleared if the entire series ends + the
  /// master event is deleted on GCal.
  seriesGcalEventId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions        NegotiationSession[]
  participants    SessionParticipant[]
  invitees        SessionInvitee[]
  consentRequests ConsentRequest[]
  mcpCallLogs     MCPCallLog[]
  occurrences     LinkOccurrence[]

  @@index([slug])
  @@index([slug, code])
}

/// Sparse per-occurrence divergence from a recurring NegotiationLink. A row
/// exists only when that occurrence deviates from the RRULE-derived default —
/// cancelled, rescheduled, format-changed, or location-changed. Occurrences
/// without a row are "nominal" and use the link-level recurrence config.
///
/// Identity is (linkId, originalStartAt): the stable anchor is the originally
/// scheduled start time in UTC, derived from the RRULE. If the host reschedules
/// the instance, actualStartAt carries the new time; originalStartAt does NOT
/// move — this mirrors GCal's `originalStartTime` on instance overrides.
///
/// counterpartyAck gates host-initiated TIME changes (proposal R4). For non-
/// time overrides (format, location, cancel), the non-diverging side's
/// acceptance can be auto-set at divergence time.
model LinkOccurrence {
  id               String          @id @default(cuid())
  linkId           String
  link             NegotiationLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  /// UTC instant of the original (RRULE-derived) start. Stable identity — does
  /// not move on reschedule.
  originalStartAt  DateTime
  /// "cancelled" | "rescheduled" | "format_changed" | "location_changed"
  status           String
  actualStartAt    DateTime?
  actualEndAt      DateTime?
  actualFormat     String?
  actualLocation   String?
  actualMeetingUrl String?
  /// Google Calendar event id of the specific instance override (recurringEventId
  /// points at the master; this id is the instance). Null when we haven't yet
  /// materialized the GCal instance.
  gcalInstanceId   String?
  /// "host" | "guest" — who initiated the divergence.
  divergedBy       String
  divergedAt       DateTime        @default(now())
  /// null until the counterparty confirms a host-initiated TIME change.
  /// For non-time divergences, auto-set to "accepted" at divergence time since
  /// either side can freely change format/location within rescheduleWindowDays.
  /// "accepted" | "rejected" | null.
  counterpartyAck  String?
  reason           String?

  @@unique([linkId, originalStartAt])
  @@index([linkId, status])
}

/// Durable notification stream for the host. Every change that per proposal
/// 2026-04-22 R2 "always notify" needs to reach a counterparty writes a row
/// here — host-facing notifications only in v1, keyed by `userId`. Guest-side
/// notifications for no-account guests fan out via email (Case C); for
/// account guests, the same `kind` values are emitted with `userId` = guest.
///
/// The bell UI + notification center are v1.1+ (see WISHLIST
/// `notification-bell-and-center`). This model is the v1 write-only stub —
/// rows land here so nothing is silent at the data layer even before the UI
/// exists.
///
/// `ctaKind` + `ctaPayload` let a future inline affordance ("Confirm this
/// move") do a one-click dispatch without re-fetching context. Nullable for
/// notifications that are purely informational.
model Notification {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Event taxonomy. v1 starting set:
  /// "schedule_changed" | "awaiting_ack_counterparty" | "awaiting_ack_self"
  /// | "ack_timed_out" | "session_confirmed" | "session_cancelled"
  /// | "series_started" | "series_ended" | "guest_signed_up"
  /// New kinds added over time — stored as string, not enum, so app-layer
  /// forward-compat is easier (unknown kinds render as a generic row).
  kind             String
  sessionId        String?
  linkId           String?
  linkOccurrenceId String?
  /// "host" | "guest" | "system" — who caused the event (not who gets notified).
  actorKind        String
  /// Display label for the actor. "Sam" / "you" / "Envoy". Frozen at write
  /// time (no join) so the notification reads correctly even if the counter-
  /// party's name changes or is deleted later.
  actorLabel       String?
  /// Short one-line summary, e.g. "Sam moved Friday to Thursday".
  headline         String    @db.VarChar(280)
  /// Optional longer detail body.
  detail           String?   @db.Text
  /// Action type the UI should wire to an inline CTA. null = no CTA.
  /// "ack_time" | "ack_format" | "ack_location" | "view_deal_room" | null.
  ctaKind          String?
  /// Payload shape depends on ctaKind. e.g. for ack_time:
  /// { occurrenceId, proposedStartAt, proposedEndAt }. JSON for forward-compat.
  ctaPayload       Json?
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NegotiationSession {
  id                   String    @id @default(cuid())
  linkId               String
  hostId               String
  guestId              String?
  type                 String    @default("calendar") // calendar | rfp
  status               String    @default("active") // active | agreed | cancelled | escalated | expired
  archived             Boolean   @default(false)
  /// Timestamp of cancellation. Null until status flips to "cancelled".
  /// Set by cancelSession() in src/lib/cancel-pipeline.ts.
  cancelledAt          DateTime?
  /// Who initiated the cancellation: "host" | "guest" | "external" | "agent".
  /// "external" = host deleted the event directly in Google Calendar (detected
  /// by the drift-detection cron). "agent" = the host's Envoy cancelled on
  /// their behalf. Drives statusLabel + system message phrasing.
  cancelledByRole      String?
  /// Optional freeform note from whoever cancelled. Appended to the deal-room
  /// system message and surfaced in the cancelled-state banner.
  cancellationNote     String?   @db.Text
  /// Timestamp of the FIRST cron cycle that observed the confirmed
  /// calendarEventId missing from Google (events.get → 404). Null means
  /// either the event still exists or we haven't yet observed drift. On
  /// the second consecutive daily cycle where the event is still missing,
  /// the drift-detection cron promotes the session to status "cancelled"
  /// (initiator "external") so AE state matches what the host did in
  /// Google directly. Cleared if the event reappears (host undid, or
  /// first-observation was a transient Google error). See Phase 7 of
  /// /api/cron/daily and proposal calendar-popup-cancel-reschedule-ctas.
  gcalDriftFirstSeenAt DateTime?
  title                String? // "Q2 Roadmap — Sarah Chen"
  statusLabel          String? // "Waiting for Sarah", "Confirmed", etc.
  meetingType          String? // phone | video | in-person
  duration             Int? // minutes
  format               String?
  agreedTime           DateTime?
  agreedFormat         String?
  summary              String?   @db.Text
  meetLink             String?
  /// Google Calendar event ID of the confirmed meeting event.
  /// Saved on confirmation so cancel can delete it cleanly.
  calendarEventId      String?
  guestEmail           String?
  /// Guest's display name, captured on the confirm card. Session-scoped so a
  /// single primary link can host many named guests without overwriting
  /// link.inviteeName. Used in the confirmed event card, calendar invite
  /// attendee name, and reminder emails.
  guestName            String?
  /// IANA timezone captured from the guest's browser on first visit
  /// (Intl.DateTimeFormat().resolvedOptions().timeZone). First-write-wins —
  /// not overwritten on subsequent visits. Null when the guest visited
  /// before we started capturing, or when detection failed.
  guestTimezone        String?
  /// IANA timezone the viewer is currently operating in for the deal-room card
  /// and Envoy's follow-up chat. Written on first card render (using
  /// detected-guest-tz if ≠ host, else host tz) AND on every picker tap —
  /// picker is authoritative, overrides browser on re-reads. When
  /// viewerTimezone !== hostTimezone, composer.ts enters dual-tz mode and
  /// dual-renders times in all follow-up responses (host-first format).
  /// Greeting prose is exempt — stays single-tz host-canonical regardless.
  viewerTimezone       String?
  /// Whether to send the guest a 24h-ahead reminder email. Default true (opt-in).
  /// Set on the confirm card via the reminder checkbox. The daily cron scans
  /// sessions where this is true + status=agreed + agreedTime falls in the
  /// now+23h..now+25h window. Idempotency via SideEffectLog.
  wantsReminder        Boolean   @default(true)
  /// Guest-agreed activity override (e.g. "coffee"). Overrides link.rules.activity at confirm time.
  /// Set by lock_activity_location agent action; cleared if host subsequently edits link.rules.activity.
  negotiatedActivity   String?
  /// Guest-agreed location (e.g. "Blue Bottle on Valencia"). Overrides link.rules.location at confirm time.
  /// Session-only — no dual-write to link.rules. Cleared if host edits link.rules.location.
  negotiatedLocation   String?
  /// Format derived from guest-negotiated activity (e.g. "in-person" for coffee, "phone" for phone call).
  /// Overrides the body format param at confirm time when set.
  negotiatedFormat     String?
  /// Guest-negotiated meeting duration in minutes (e.g. 60). Overrides link.parameters.duration
  /// at slot-search and confirm time. Set by lock_session_duration agent action when the host
  /// has opted into guestPicks.duration. Cleared if the host subsequently edits the link's
  /// duration. Reusable-link guest-picks proposal, decided 2026-04-28.
  negotiatedDuration   Int?
  /// Who last wrote the negotiated values. Always "guest" in v1; "host" reserved for future multi-round use.
  negotiatedLockedBy   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  link            NegotiationLink     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  host            User                @relation("host", fields: [hostId], references: [id])
  guest           User?               @relation("guest", fields: [guestId], references: [id])
  messages        Message[]
  proposals       Proposal[]
  channelMessages ChannelMessage[]
  outcome         NegotiationOutcome?
  participants    SessionParticipant[]
  invitees        SessionInvitee[]
  slotRsvps       InviteeSlotRsvp[]
  holds           Hold[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String // administrator | guest | system
  content   String   @db.Text
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  session   NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposals Proposal[]
}

model Proposal {
  id        String    @id @default(cuid())
  sessionId String
  messageId String?
  dateTime  DateTime?
  duration  Int? // minutes
  format    String? // phone | video | in-person
  location  String?
  tier      Int       @default(1) // 1 | 2 | 3
  status    String    @default("offered") // offered | accepted | rejected | countered
  createdAt DateTime  @default(now())

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message Message?           @relation(fields: [messageId], references: [id])
}

// NegotiationOutcome: tracks results of confirmed negotiations for learning
model NegotiationOutcome {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  exchangeCount         Int // guest messages only (not system/greeting)
  tierReached           Int      @default(1) // 1 | 2 | 3
  guestCounterProposed  Boolean  @default(false)
  timeToConfirmationSec Int? // seconds from session creation to confirmation
  proposedFormat        String? // what the agent first proposed
  agreedFormat          String? // what was actually confirmed
  participantCount      Int      @default(2) // total participants including host
  feedback              String?  @db.Text // open-ended guest feedback
  createdAt             DateTime @default(now())

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Channel: the host's dashboard chat — one per user
model Channel {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChannelMessage[]
  sessions  ChannelSession[]
  createdAt DateTime         @default(now())
}

// SessionParticipant: an arrival on a session — a human clicking in, or an
// agent connecting via MCP. Multiple arrivals per session are valid (agent +
// human, phone + desktop). Arrival may point at a SessionInvitee it fulfills;
// when null, the arrival is an uninvited click-through (forwarded link).
//
// 2026-04-23: dropped `@unique([sessionId])` and split invite from arrival
// (see SessionInvitee). Track 1 multi-user coordination proposal, path B.
model SessionParticipant {
  id               String   @id @default(cuid())
  linkId           String
  sessionId        String
  sessionInviteeId String?  // nullable — arrival may not match any invite
  userId           String?
  email            String?
  name             String?
  role             String   @default("guest") // "host" | "guest"
  status           String   @default("pending") // "pending" | "active" | "agreed" | "declined"
  joinedAt         DateTime @default(now())

  link           NegotiationLink    @relation(fields: [linkId], references: [id])
  session        NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User?              @relation(fields: [userId], references: [id])
  sessionInvitee SessionInvitee?    @relation(fields: [sessionInviteeId], references: [id])

  @@unique([linkId, email])
  @@index([linkId])
  @@index([sessionId])
  @@index([sessionInviteeId])
}

// SessionInvitee: an invite on a session — the host-defined, stable record of
// "Will is on the invite for this meeting." One row per named invitee at
// create_link time. Arrivals (SessionParticipant) attach via sessionInviteeId;
// RSVPs (InviteeSlotRsvp) attach via sessionInviteeId.
//
// Separated from SessionParticipant because invite-state and arrival-state
// diverge in several real scenarios: guest-agent acts before the human shows
// up (one invite, multiple arrivals), host uninvites someone who already sent
// messages (arrival stays, invite deleted), forwarded-link click yields an
// arrival with no invite. Track 1 multi-user coordination proposal, path B.
model SessionInvitee {
  id        String   @id @default(cuid())
  linkId    String
  sessionId String
  name      String
  email     String?
  role      String   @default("guest")
  createdAt DateTime @default(now())

  link         NegotiationLink      @relation(fields: [linkId], references: [id], onDelete: Cascade)
  session      NegotiationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participants SessionParticipant[]
  rsvps        InviteeSlotRsvp[]

  @@index([sessionId])
  @@index([linkId])
}

// InviteeSlotRsvp: per-slot per-invitee availability state for links with
// partialAttendance enabled. Status transitions:
//   - "tentative"  → pre-arrival guess (from linked calendar)
//   - "confirmed"  → invitee (or their agent) explicitly accepted this slot
//   - "declined"   → invitee (or their agent) explicitly rejected this slot
//   - "excused"    → confirm pipeline booked without them; courtesy email sent
//
// Written only when link.rules.partialAttendance === "allowed". Single-guest
// and whole-attendance links write zero rows. See 2026-04-23 multi-user
// coordination proposal §Confirm pipeline for the CAS logic.
model InviteeSlotRsvp {
  id               String   @id @default(cuid())
  sessionId        String
  sessionInviteeId String
  slotStart        DateTime
  slotEnd          DateTime
  status           String   // "tentative" | "confirmed" | "declined" | "excused"
  createdAt        DateTime @default(now())

  sessionInvitee SessionInvitee     @relation(fields: [sessionInviteeId], references: [id], onDelete: Cascade)
  session        NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sessionInviteeId])
  @@index([sessionInviteeId, slotStart])
}

// ChannelMessage: feed-level messages between user and Envoy
model ChannelMessage {
  id        String              @id @default(cuid())
  channelId String
  channel   Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      String // "user" | "envoy" | "system"
  content   String              @db.Text
  threadId  String? // FK to NegotiationSession — renders as ThreadCard in feed
  thread    NegotiationSession? @relation(fields: [threadId], references: [id])
  metadata  Json?               @default("{}")
  createdAt DateTime            @default(now())

  @@index([channelId])
  @@index([threadId])
}

// CalendarCache: cached calendar events per user per calendar (incremental sync via syncToken)
model CalendarCache {
  id           String   @id @default(cuid())
  userId       String
  calendarId   String // Google Calendar ID (e.g., "primary", "family@group.calendar.google.com")
  calendarName String
  syncToken    String? // Google's nextSyncToken for incremental sync
  events       Json     @default("[]") // CalendarEvent[] — current state of this calendar
  lastSyncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, calendarId])
  @@index([userId])
}

// ComputedSchedule: pre-scored 30-min slots for the next 2 weeks
model ComputedSchedule {
  id         String   @id @default(cuid())
  userId     String   @unique
  slots      Json     @default("[]") // ScoredSlot[] — protection scores -1 to 5
  computedAt DateTime @default(now())
  inputHash  String   @default("") // hash of (events + preferences) — skip recompute if unchanged

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ChannelSession: conversational window in the host's dashboard chat
model ChannelSession {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  startedAt DateTime @default(now())
  expiresAt DateTime // rolling: last message + 3 days
  summary   String?  @db.Text // LLM-generated summary when session closes
  closed    Boolean  @default(false)

  @@index([channelId])
}

// NegotiatorResult: persisted results from the multi-agent negotiator tool
model NegotiatorResult {
  id                 String   @id @default(cuid())
  shareCode          String   @unique
  question           String   @db.Text
  agents             Json // AgentConfig[] minus apiKey
  research           Json // ResearchResult[]
  syntheses          Json // Synthesis[]
  humanDecisions     Json     @default("[]")
  hostClarifications Json     @default("[]")
  finalResponses     Json     @default("[]")
  adminSummary       String?  @db.Text
  totalTokens        Int      @default(0)
  transcript         String   @db.Text
  usageRows          Json     @default("[]") // UsageRow[] — per-step token/cost/time breakdown
  createdAt          DateTime @default(now())
}

/// Tentative protective hold placed on a specific stretch slot by an explicit
/// host decision in the dashboard thread. The hold creates a real tentative
/// event on the host calendar so concurrent bookings can't grab the slot
/// while the guest decides. Host-initiated only; never automatic. Expires
/// after 48h or when the associated session's meeting gets confirmed.
model Hold {
  id              String   @id @default(cuid())
  sessionId       String
  hostId          String
  slotStart       DateTime
  slotEnd         DateTime
  /// Google Calendar event ID of the tentative event backing this hold.
  /// Null if calendar is read-only (hold is "best-effort" in that case).
  calendarEventId String?
  /// Hold state: active (live), released (host cancelled), satisfied
  /// (meeting confirmed and promoted to a real event), expired (48h elapsed).
  status          String   @default("active") // active | released | satisfied | expired
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([hostId])
  @@index([status, expiresAt]) // for the expiry sweeper
}

/// Audit trail for every outbound side effect (email, calendar, MCP callback, ...)
/// dispatched through `src/lib/side-effects/dispatcher.ts`.
///
/// Every dispatch writes exactly one row — including when mode is `log`/`dryrun`
/// and no external service was contacted. This is the "what actually happened"
/// record; queryable via `/dev/side-effects`. See RISK-MANAGEMENT.md.
model SideEffectLog {
  id            String   @id @default(cuid())
  /// SideEffect.kind (e.g. "email.send", "calendar.create_event")
  kind          String
  /// Active EffectMode at dispatch time
  mode          String
  /// Terminal EffectStatus: sent | suppressed | dryrun | failed | skipped
  status        String
  /// Short human-readable target (e.g. "mike@example.com" or "host calendar")
  /// — scrubbed of anything that wouldn't be OK in a log line.
  targetSummary String
  /// Full effect payload, minus secrets. Safe to dump on the dashboard.
  payload       Json
  /// Optional structured context from the caller (sessionId, userId, etc.).
  contextJson   Json?
  /// Provider-assigned message ID or fake dryrun ID. Optional.
  providerRef   String?
  /// Error message if status === "failed".
  error         String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([kind, createdAt])
  @@index([status, createdAt])
}

/// Audit trail for every `/api/negotiate/confirm` attempt. Every entry
/// to the route writes exactly one row, regardless of outcome — so we
/// have a durable record even when Vercel function logs rotate or a
/// timeout swallows the response. Read at `/admin/failures`.
model ConfirmAttempt {
  id           String    @id @default(cuid())
  sessionId    String?
  slotStart    DateTime?
  slotEnd      DateTime?
  /// success | already_agreed | slot_mismatch | gcal_failed | server_error | validation_failed
  outcome      String
  errorMessage String?   @db.Text
  /// Truncated to 200 chars; raw UA scrubbed of other PII.
  userAgent    String?
  durationMs   Int?
  createdAt    DateTime  @default(now())

  @@index([sessionId, createdAt])
  @@index([outcome, createdAt])
}

/// Generic route-error audit trail. Any API route can call
/// `logRouteError()` (`src/lib/route-error.ts`) to persist a server-side
/// error. Shown on `/admin/failures` alongside ConfirmAttempt and
/// SideEffectLog failures.
model RouteError {
  id          String   @id @default(cuid())
  route       String
  method      String?
  statusCode  Int?
  errorClass  String?
  message     String   @db.Text
  stack       String?  @db.Text
  contextJson Json?
  userId      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([route, createdAt])
  @@index([createdAt])
}

/// Rate-limit counter for MCP tool calls. One row per (capabilityToken,
/// tool, windowStart). Incremented via UPSERT with ON CONFLICT DO UPDATE
/// — atomic under READ COMMITTED (Postgres default): the DO UPDATE takes
/// a row-level lock and the `CASE` in the SET clause evaluates against
/// the post-lock row state, so concurrent increments cannot lose counts.
/// See `src/lib/mcp/rate-limit.ts` and SPEC §1.
///
/// `windowStart` is the bucket boundary (e.g., floor(NOW() / 60s) for a
/// 60-second window). When the server-side clock passes the boundary,
/// the CASE resets count to 1 and updates windowStart; otherwise it
/// increments count in place. Server-side NOW() is used (not client
/// clock) to defeat skew attacks.
///
/// `expiresAt` is used by the hourly sweep cron to GC expired rows.
model MCPRateCounter {
  id          String   @id @default(cuid())
  /// SHA-256 hash of the capability token (the `/meet/<slug>?c=<code>`
  /// URL fragment acting as the MCP bearer). Never store plaintext.
  tokenHash   String
  /// MCP tool name, e.g. "propose_lock", "post_message".
  tool        String
  /// ISO timestamp of the window's start (server-side NOW(), floored).
  windowStart DateTime
  count       Int      @default(1)
  /// `windowStart + windowDurationSec`. Cron GCs rows past this.
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tokenHash, tool, windowStart])
  @@index([expiresAt])
}

/// Host consent record for any MCP-initiated change to a negotiable
/// parameter. Written by `propose_lock` when the external agent wants to
/// change a field the host hasn't pre-committed. Status transitions:
/// pending → accepted | retracted | expired.
///
/// The invariant: `propose_lock` refuses with `consent_not_accepted` if
/// ANY matching ConsentRequest exists in a non-accepted terminal state
/// ({pending, retracted, expired}). No soft tolerance, no silent
/// fall-through to defaults. See `src/lib/mcp/consent-request.ts` and
/// SPEC §2.
model ConsentRequest {
  id                String    @id @default(cuid())
  linkId            String
  sessionId         String?
  /// Logical field name — e.g., "format", "location", "duration", "date".
  /// Treated as a string in Prisma; Zod schemas at the MCP boundary
  /// union-type this against the field enum used elsewhere.
  field             String
  /// The structured value being requested. `propose_lock` reads this
  /// verbatim; prose is NEVER the source of truth (see §3).
  appliedValue      Json
  /// Human-readable template with allow-listed placeholders — see
  /// `src/lib/mcp/placeholders.ts`. Stored for audit; not rendered live
  /// without running through the rationale validator.
  rationaleTemplate String?
  /// LLM-generated prose accompanying the request. Shown LIVE in the
  /// deal-room; NEVER logged to MCPCallLog (redaction table §7 drops it).
  /// Validated post-generation for URL/email/phone/length; on trip, the
  /// UI falls back to template-rendered output instead. See §3.
  rationaleProse    String?   @db.Text
  status            String    @default("pending") // pending | accepted | retracted | expired
  /// Who decided. `guest` = human clicked OK; `host_envoy` = host's
  /// Envoy accepted on their behalf; `system_expired` = timeout.
  decidedBy         String?
  decidedAt         DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  link NegotiationLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, field, status])
  @@index([sessionId, status])
  @@index([expiresAt])
}

/// Append-only audit log of every MCP tool invocation. Fed by the MCP HTTP
/// route after redaction via `src/lib/mcp/call-log.ts` (SPEC §7). The
/// redaction table is the single source of truth for what may land in
/// `requestBody` / `responseBody`; in particular `rationaleProse` is
/// DROPPED (never stored) and guest emails arrive pre-hashed per §4.
///
/// FK to NegotiationLink cascades on link deletion — a tenant erasing a
/// link erases their log rows with it. `sessionId` is nullable because
/// tools like `get_meeting_parameters` fire before any session exists.
model MCPCallLog {
  id           String   @id @default(cuid())
  ts           DateTime @default(now())
  linkId       String
  sessionId    String?
  /// MCP tool name: propose_lock, post_message, get_session_status, etc.
  tool         String
  /// Self-reported by the caller; untrusted metadata. Surfaced in the
  /// deal-room banner alongside the 🤖 badge (see
  /// `src/components/deal-room-role-dispatch.ts`).
  clientName   String?
  clientType   String?
  /// Optional `{name, email?}` — email arrives pre-hashed via
  /// `hashGuestEmail(link.hashSalt, ...)` before reaching this row.
  principal    Json?
  /// Tool arguments after redaction. Schema-driven; never ad-hoc.
  requestBody  Json
  /// Tool response after redaction. `rationaleProse` is always dropped.
  responseBody Json
  /// "ok" | "error:<code>" — cheap filter for dashboard queries.
  outcome      String
  /// End-to-end tool latency in ms, including DB writes and rate-limit
  /// check. Null on early-abort paths (e.g. link lookup 404).
  latencyMs    Int?

  link NegotiationLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, ts])
  @@index([sessionId, ts])
  @@index([tool, ts])
}
