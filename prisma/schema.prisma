generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// AgentEnvoy models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  meetSlug      String?   @unique
  preferences      Json?     @default("{}")
  hostDirectives   Json?     @default("[]") // string[] — global ::: directives that shape all negotiations
  persistentKnowledge  String?   @db.Text   // Long-lived: who they are, how they work, what matters
  situationalKnowledge String?   @db.Text   // Near-term: this week's overrides, upcoming context, temporary rules
  lastCalibratedAt DateTime?              // null = never calibrated, triggers onboarding flow
  createdAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  negotiationLinks   NegotiationLink[]
  hostedSessions     NegotiationSession[] @relation("host")
  guestSessions      NegotiationSession[] @relation("guest")
  participations     SessionParticipant[]
  apiKeys            ApiKey[]
  channel            Channel?
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique // SHA-256 hash of the plaintext key
  userId     String
  name       String    @default("Default")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
}

model NegotiationLink {
  id           String   @id @default(cuid())
  userId       String
  type         String   @default("generic") // generic | contextual
  mode         String   @default("single")  // "single" | "group"
  slug         String   // same as user.meetSlug for generic
  code         String?  @unique // unique code for contextual links
  inviteeEmail String?
  inviteeName  String?
  topic        String?
  rules        Json?    @default("{}")
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     NegotiationSession[]
  participants SessionParticipant[]

  @@index([slug])
  @@index([slug, code])
}

model NegotiationSession {
  id            String   @id @default(cuid())
  linkId        String
  hostId        String
  guestId       String?
  type          String   @default("calendar") // calendar | rfp
  status        String   @default("active") // active | agreed | escalated | expired
  archived      Boolean  @default(false)
  title         String?  // "Q2 Roadmap — Sarah Chen"
  statusLabel   String?  // "Waiting for Sarah", "Confirmed", etc.
  meetingType   String?  // phone | video | in-person
  duration      Int?     // minutes
  format        String?
  agreedTime    DateTime?
  agreedFormat  String?
  summary       String?  @db.Text
  meetLink      String?
  guestEmail     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  link            NegotiationLink    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  host            User               @relation("host", fields: [hostId], references: [id])
  guest           User?              @relation("guest", fields: [guestId], references: [id])
  messages        Message[]
  proposals       Proposal[]
  channelMessages ChannelMessage[]
  outcome         NegotiationOutcome?
  participant     SessionParticipant?
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // administrator | guest | system
  content   String   @db.Text
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  session   NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposals Proposal[]
}

model Proposal {
  id        String   @id @default(cuid())
  sessionId String
  messageId String?
  dateTime  DateTime?
  duration  Int?     // minutes
  format    String?  // phone | video | in-person
  location  String?
  tier      Int      @default(1) // 1 | 2 | 3
  status    String   @default("offered") // offered | accepted | rejected | countered
  createdAt DateTime @default(now())

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message Message?           @relation(fields: [messageId], references: [id])
}

// NegotiationOutcome: tracks results of confirmed negotiations for learning
model NegotiationOutcome {
  id                     String   @id @default(cuid())
  sessionId              String   @unique
  exchangeCount          Int      // guest messages only (not system/greeting)
  tierReached            Int      @default(1) // 1 | 2 | 3
  guestCounterProposed   Boolean  @default(false)
  timeToConfirmationSec  Int?     // seconds from session creation to confirmation
  proposedFormat         String?  // what the agent first proposed
  agreedFormat           String?  // what was actually confirmed
  participantCount       Int      @default(2) // total participants including host
  feedback               String?  @db.Text // open-ended guest feedback
  createdAt              DateTime @default(now())

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Channel: the host's dashboard chat — one per user
model Channel {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChannelMessage[]
  createdAt DateTime         @default(now())
}

// SessionParticipant: tracks each person in a group event
model SessionParticipant {
  id        String   @id @default(cuid())
  linkId    String
  sessionId String   @unique
  userId    String?
  email     String?
  name      String?
  role      String   @default("guest")    // "host" | "guest"
  status    String   @default("pending")  // "pending" | "active" | "agreed" | "declined"
  joinedAt  DateTime @default(now())

  link    NegotiationLink    @relation(fields: [linkId], references: [id])
  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?              @relation(fields: [userId], references: [id])

  @@unique([linkId, email])
  @@index([linkId])
}

// ChannelMessage: feed-level messages between user and Envoy
model ChannelMessage {
  id        String              @id @default(cuid())
  channelId String
  channel   Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      String              // "user" | "envoy" | "system"
  content   String              @db.Text
  threadId  String?             // FK to NegotiationSession — renders as ThreadCard in feed
  thread    NegotiationSession? @relation(fields: [threadId], references: [id])
  metadata  Json?               @default("{}")
  createdAt DateTime            @default(now())

  @@index([channelId])
  @@index([threadId])
}

// NegotiatorResult: persisted results from the multi-agent negotiator tool
model NegotiatorResult {
  id                 String   @id @default(cuid())
  shareCode          String   @unique
  question           String   @db.Text
  agents             Json     // AgentConfig[] minus apiKey
  research           Json     // ResearchResult[]
  syntheses          Json     // Synthesis[]
  humanDecisions     Json     @default("[]")
  hostClarifications Json     @default("[]")
  finalResponses     Json     @default("[]")
  adminSummary       String?  @db.Text
  totalTokens        Int      @default(0)
  transcript         String   @db.Text
  createdAt          DateTime @default(now())
}
