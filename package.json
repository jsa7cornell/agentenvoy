{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "check": "prisma generate && tsc --noEmit && next lint",
    "lint": "next lint",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "INTEGRATION_TEST_DB_OK=1 vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts",
    "test:e2e:browser": "playwright test",
    "test:e2e:browser:ui": "playwright test --ui",
    "test:e2e:browser:install": "playwright install chromium",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:e2e:browser",
    "db:migrate:dev": "tsx scripts/safe-prisma.ts migrate dev",
    "db:migrate:reset": "tsx scripts/safe-prisma.ts migrate reset",
    "db:push:reset": "tsx scripts/safe-prisma.ts db push --force-reset",
    "bench:intent": "tsx scripts/bench-intent/run.ts",
    "eval:extract-candidates": "tsx scripts/eval-candidates/extract.ts",
    "eval:promptfoo": "promptfoo eval --config eval/promptfoo.config.yaml",
    "eval:langfuse:up": "docker compose -f docker-compose.langfuse.yml up -d",
    "eval:langfuse:down": "docker compose -f docker-compose.langfuse.yml down",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.59",
    "@ai-sdk/openai": "^3.0.51",
    "@auth/prisma-adapter": "^1.6.0",
    "@aws-sdk/client-sesv2": "^3.1031.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@vercel/functions": "^1.5.0",
    "ai": "^6.0.144",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unpdf": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^9.1.7",
    "langfuse": "^3.38.20",
    "postcss": "^8",
    "promptfoo": "^0.121.8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
