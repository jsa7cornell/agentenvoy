{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/schema-health",
      "schedule": "0 16 * * *"
    }
  ],
  "env": {
    "GOOGLE_WATCH_DISABLED": "1"
  },
  "build": {
    "env": {
      "GOOGLE_WATCH_DISABLED": "1"
    }
  }
}
